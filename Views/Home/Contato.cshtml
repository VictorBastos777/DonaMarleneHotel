@{
    ViewData["Title"] = "Contato";
}

<!-- PAGE HEADER -->
<section class="page-header">
    <div class="page-header-overlay"></div>
    <img src="/images/hotel_lobby.png" alt="Contato" class="page-header-bg" />
    <div class="page-header-content">
        <span class="hero-badge">✦ Fale Conosco</span>
        <h1>Entre em <span class="hero-highlight">Contato</span></h1>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="contato-grid fade-in">

            <!-- INFO -->
            <div class="contato-info">
                <h2>Informações de Contato</h2>
                <p>Estamos prontos para atendê-lo! Entre em contato pelo WhatsApp ou pelas informações abaixo.</p>

                <div class="contato-item">
                    <span class="contato-icon">📍</span>
                    <div>
                        <strong>Endereço</strong>
                        <p>R. Quinze de Novembro - Codajás, AM, 69450-000</p>
                    </div>
                </div>

                <div class="contato-item">
                    <span class="contato-icon">📞</span>
                    <div>
                        <strong>Telefone / WhatsApp</strong>
                        <p><a href="tel:+5597991512365">(97) 99151-2365</a></p>
                    </div>
                </div>


                <!-- GRANDE BOTÃO WHATSAPP -->
                <a href="https://wa.me/5597991512365?text=Ol%C3%A1%21+Gostaria+de+saber+mais+sobre+o+Dona+Marlene+Hotel."
                   target="_blank" class="btn btn-whatsapp btn-lg btn-full" id="contatoWhatsappBtn">
                    <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
                    </svg>
                    Chamar no WhatsApp Agora
                </a>
            </div>

            <!-- FORMULÁRIO VISUAL -->
            <div class="contato-form-box">
                <h3>Envie uma Mensagem</h3>
                <p class="form-note">Preencha abaixo e enviaremos por WhatsApp:</p>
                <form class="contato-form" id="contatoForm">
                    <div class="form-group">
                        <label for="nome">Seu Nome</label>
                        <input type="text" id="nome" placeholder="Ex: João Silva" />
                    </div>
                    <div class="form-group">
                        <label for="mensagem">Mensagem</label>
                        <textarea id="mensagem" rows="5" placeholder="Olá! Gostaria de saber..."></textarea>
                    </div>
                    <button type="button" class="btn btn-whatsapp btn-full" onclick="enviarWhatsapp()" id="enviarMsgBtn">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
                        </svg>
                        Enviar pelo WhatsApp
                    </button>
                </form>
            </div>

        </div>

        <!-- MAPA -->
        <div class="mapa-container fade-in">
            <h3>Nossa Localização</h3>
            <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3980.8430214056157!2d-62.0633489!3d-3.8430214!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x9214ffa60e2baa89%3A0xfe795dc2ec35db6e!2sHotel%20Dona%20Marlene!5e0!3m2!1spt-BR!2sbr!4v1741912028641!5m2!1spt-BR!2sbr"
                width="100%"
                height="400"
                style="border:0; border-radius: 12px;"
                allowfullscreen=""
                loading="lazy"
                title="Localização do Dona Marlene Hotel em Codajás">
            </iframe>
        </div>
    </div>
</section>
