@{
    ViewData["Title"] = "Sobre";
}

<!-- PAGE HEADER -->
<section class="page-header">
    <div class="page-header-overlay"></div>
    <img src="/images/hotel_lobby.png" alt="Sobre o Hotel" class="page-header-bg" />
    <div class="page-header-content">
        <span class="hero-badge">✦ Nossa História</span>
        <h1>Sobre o <span class="hero-highlight">Hotel</span></h1>
    </div>
</section>

<!-- NOSSA HISTÓRIA -->
<section class="section">
    <div class="container">
        <div class="sobre-grid fade-in">
            <div class="sobre-text">
                <span class="section-tag">Tradição Amazonense</span>
                <h2>Uma história de hospitalidade</h2>
                <p>O Dona Marlene Hotel nasceu do sonho de oferecer acolhimento genuíno a todos que chegam a Codajás, seja para trabalho, turismo ou simplesmente para conhecer as maravilhas do Amazonas.</p>
                <p>Localizado no coração de Codajás — a "Terra do açaí" —, nosso hotel combina o agito da cidade com a tranquilidade e a beleza única da Amazônia.</p>
                <p>Com atendimento familiar e dedicado, cada detalhe foi pensado para que sua estadia seja confortável, segura e memorável. Nosso compromisso é transformar cada visita em uma experiência que você vai querer repetir.</p>
                <div class="sobre-stats">
                    <div class="stat">
                        <span class="stat-number">100%</span>
                        <span class="stat-label">Dedicação</span>
                    </div>
                    <div class="stat">
                        <span class="stat-number">24h</span>
                        <span class="stat-label">Atendimento</span>
                    </div>
                    <div class="stat">
                        <span class="stat-number">★★★</span>
                        <span class="stat-label">Qualidade</span>
                    </div>
                </div>
            </div>
            <div class="sobre-image">
                <img src="/images/hotel_hero.png" alt="Dona Marlene Hotel" />
                <div class="sobre-image-badge">
                    <span>📍 Codajás, AM</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CODAJÁS SECTION -->
<section class="section section-dark">
    <div class="container">
        <div class="section-header fade-in">
            <span class="section-tag" style="color: var(--amarelo);">Conheça Codajás</span>
            <h2 style="color: white;">A Terra da Vitória-Régia</h2>
            <p style="color: rgba(255,255,255,0.75);">Codajás é um município encantador do interior do Amazonas, às margens do Rio Solimões. Com paisagens amazônicas deslumbrantes, fauna e flora riquíssimas e um povo hospitaleiro, é destino imperdível para quem visita a região.</p>
        </div>
        <div class="codajas-grid fade-in">
            <div class="codajas-card">
                <span class="codajas-icon">🌊</span>
                <h3>Rio Solimões</h3>
                <p>Às margens do majestuoso Rio Solimões, a cidade oferece passeios e vistas únicas da natureza amazônica.</p>
            </div>
            <div class="codajas-card">
                <span class="codajas-icon">🌺</span>
                <h3>Vitória-Régia</h3>
                <p>Símbolo da cidade, a famosa Vitória-Régia pode ser encontrada nas águas e lagos ao redor de Codajás.</p>
            </div>
            <div class="codajas-card">
                <span class="codajas-icon">🐟</span>
                <h3>Pesca e Natureza</h3>
                <p>Pesca esportiva, turismo ecológico e trilhas pela Floresta Amazônica são atrações imperdíveis da região.</p>
            </div>
        </div>
    </div>
</section>

<!-- ESTRUTURA SECTION -->
<section class="section">
    <div class="container">
        <div class="section-header fade-in">
            <span class="section-tag">Nossa Estrutura</span>
            <h2>Conforto em Cada Detalhe</h2>
        </div>
        <div class="estrutura-list fade-in">
            <div class="estrutura-item">✓ Quartos climatizados com ar-condicionado</div>
            <div class="estrutura-item">✓ Wi-Fi de alta velocidade</div>
            <div class="estrutura-item">✓ TV a cabo em todos os quartos</div>
            <div class="estrutura-item">✓ Recepção disponível 24 horas</div>
            <div class="estrutura-item">✓ Estacionamento próprio</div>
            <div class="estrutura-item">✓ Área de descanso e lazer</div>
            <div class="estrutura-item">✓ Roupa de cama e banho incluídos</div>
            <div class="estrutura-item">✓ Localização central em Codajás</div>
        </div>
    </div>
</section>
